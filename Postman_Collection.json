        {
            "name": "5. [Student] Get Request Types (Fetch Bonafide ID)",
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "exec": [
                            "var response = pm.response.json();",
                            "if(response.success) {",
                            "    var bonafide = response.data.find(t => t.code === 'BONAFIDE');",
                            "    if(bonafide) {",
                            "        pm.environment.set('request_type_id', bonafide.id);",
                            "    }",
                            "}"
                        ],
                        "type": "text/javascript"
