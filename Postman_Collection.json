    "item": [
        {
            "name": "1. [Student] Register",
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "exec": [
                            "var response = pm.response.json();",
                            "pm.test('Student registered successfully', function() {",
                            "    pm.expect(response.success).to.be.true;",
                            "    pm.environment.set('student_user_id', response.data.id);",
                            "});"
                        ],
                        "type": "text/javascript"
                    }
                },
                {
                    "listen": "prerequest",
                    "script": {
                        "exec": [
                            "pm.environment.set('student_email', 'automated_student_' + Date.now() + '@example.com');"
                        ],
                        "type": "text/javascript"
                    }
                }
            ],
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n    \"email\": \"{{student_email}}\",\n    \"password\": \"TestPassword123!\",\n    \"role\": \"STUDENT\"\n}"
                },
                "url": {
                    "raw": "{{base_url}}/api/auth/register",
                    "host": [
                        "{{base_url}}"
                    ],
                    "path": [
                        "api",
                        "auth",
                        "register"
                    ]
                }
            }
        },
