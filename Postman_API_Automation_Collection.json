  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.environment.get('base_url')) {",
          "  pm.environment.set('base_url', 'http://localhost:5001');",
          "}",
          "if (!pm.environment.get('student_email')) {",
          "  pm.environment.set('student_email', `student_${Date.now()}@example.com`);",
          "}",
          "if (!pm.environment.get('incharge_email')) {",
          "  pm.environment.set('incharge_email', `incharge_${Date.now()}@example.com`);",
          "}",
          "if (!pm.environment.get('password')) {",
          "  pm.environment.set('password', 'TestPassword123!');",
          "}"
        ]
      }
    }
  ],
